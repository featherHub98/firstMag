{
  "name": "firstmag",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "test:unit": "cargo test --manifest-path src-tauri/Cargo.toml --all-targets && vitest run",
    "test:integration": "cargo test --manifest-path src-tauri/Cargo.toml --test domain_tests",
    "test:e2e": "cargo run --manifest-path src-tauri/Cargo.toml --bin e2e_test",
    "test:all": "npm run lint && npm run build && npm run test:unit && npm run test:integration && npm run test:e2e",
    "preview": "vite preview",
    "tauri": "tauri"
  },
